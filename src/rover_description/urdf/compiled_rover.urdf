    <origin xyz="0.2 0 0.05"/>
  </joint>
  <!-- GAZEBO CAMERA PLUGIN -->
  <gazebo reference="camera_link">
    <sensor name="front_camera" type="camera">
      <update_rate>30.0</update_rate>
      <camera>
        <horizontal_fov>1.089</horizontal_fov>
        <image>
          <format>R8G8B8</format>
          <width>640</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
